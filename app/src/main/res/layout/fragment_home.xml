<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FocusBro"
        android:textColor="@color/black_primary"
        android:textSize="32sp"
        android:fontFamily="@font/sf_ui_bold"
        android:layout_marginTop="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Focus on what matters"
        android:textColor="@color/gray_secondary"
        android:textSize="14sp"
        android:fontFamily="@font/sf_ui_medium"
        android:layout_marginBottom="50dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/timeDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:layout_marginStart="30dp"
            android:text="25:00"
            android:textColor="@color/black_primary"
            android:textSize="72sp"
            android:fontFamily="@font/sf_ui_heavy" />

        <ImageButton
            android:id="@+id/editTimeButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_pencil"
            android:background="@null"
            android:layout_marginStart="10dp"
            android:contentDescription="Edit Time" />
    </LinearLayout>

    <Spinner
        android:id="@+id/tagSpinner"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:background="@drawable/spinner_background"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp" />

    <!-- Start Button -->
    <Button
        android:id="@+id/startButton"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Start Session"
        android:background="@drawable/bg_button"
        app:backgroundTint="@null"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="@font/sf_ui_semibold" />

    <TextView
        android:id="@+id/sessionCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="0 sessions today"
        android:textColor="@color/gray_secondary"
        android:textSize="14sp"
        android:fontFamily="@font/sf_ui_medium" />

</LinearLayout>